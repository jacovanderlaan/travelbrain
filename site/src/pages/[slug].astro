---
import { marked } from 'marked';
import content from '../content.json';

export function getStaticPaths() {
  return content.pages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
const bodyHtml = marked.parse(page.body_md);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const url = (p) => base + p;  // prefix internal paths for the Pages sub-path
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{page.title}</title>
    <meta name="description" content="Curated, design-led, adults-suitable places to eat and stay — filtered by a fixed taste, sourced from named publications." />
    <style>
      :root { --ink: #1a1a1a; --muted: #6b6b6b; --line: #e5e2dc; --bg: #faf8f5; --accent: #2a4d46; }
      * { box-sizing: border-box; }
      body { margin: 0; background: var(--bg); color: var(--ink);
        font: 17px/1.6 ui-serif, Georgia, "Times New Roman", serif; }
      .wrap { max-width: 720px; margin: 0 auto; padding: 4rem 1.5rem 6rem; }
      a.back { font: 600 12px/1 ui-sans-serif, system-ui, sans-serif; letter-spacing: .08em;
        text-transform: uppercase; color: var(--accent); text-decoration: none; }
      header.brand { font: 600 13px/1 ui-sans-serif, system-ui, sans-serif;
        letter-spacing: .14em; text-transform: uppercase; color: var(--accent); margin: 1.5rem 0 3rem; }
      figure.hero { margin: 0 0 2.5rem; }
      figure.hero img { width: 100%; height: 280px; object-fit: cover; border-radius: 6px; display: block; }
      figure.hero figcaption { font: 11px/1.4 ui-sans-serif, system-ui, sans-serif;
        color: var(--muted); margin-top: .4rem; }
      figure.hero figcaption a { color: var(--muted); }
      article h1 { font-size: 2.1rem; line-height: 1.15; margin: 0 0 1.5rem; letter-spacing: -.01em; }
      article h2 { font-size: 1.05rem; font-family: ui-sans-serif, system-ui, sans-serif;
        text-transform: uppercase; letter-spacing: .08em; color: var(--muted); margin: 2.5rem 0 1rem; }
      article p { margin: 0 0 1.1rem; }
      article strong { color: var(--ink); }
      .pois { margin-top: 3.5rem; border-top: 1px solid var(--line); padding-top: 2rem; }
      .pois h2 { font: 600 13px/1 ui-sans-serif, system-ui, sans-serif;
        letter-spacing: .14em; text-transform: uppercase; color: var(--accent); margin-bottom: 1.5rem; }
      figure.poi { margin: 0 0 2rem; display: grid; grid-template-columns: 200px 1fr; gap: 1.2rem; align-items: start; }
      figure.poi img { width: 200px; height: 150px; object-fit: cover; border-radius: 6px; display: block; }
      figure.poi figcaption .poi-name { font-weight: 600; font-size: 1.05rem; }
      figure.poi figcaption p { margin: .4rem 0 .5rem; font-size: .95rem; }
      figure.poi figcaption .poi-credit { font: 11px ui-sans-serif, system-ui, sans-serif; color: var(--muted); }
      @media (max-width: 560px) { figure.poi { grid-template-columns: 1fr; } figure.poi img { width: 100%; height: 200px; } }
      .venues { margin-top: 4rem; border-top: 1px solid var(--line); padding-top: 2rem; }
      .venues h2 { font: 600 13px/1 ui-sans-serif, system-ui, sans-serif;
        letter-spacing: .14em; text-transform: uppercase; color: var(--accent); }
      .venue { padding: 1.1rem 0; border-bottom: 1px solid var(--line);
        display: flex; gap: 1rem; align-items: flex-start; }
      .venue .body { flex: 1; }
      .venue .meta { font: 13px/1.5 ui-sans-serif, system-ui, sans-serif; color: var(--muted); }
      .venue .name { font-weight: 600; }
      .venue .sources { font-size: 12px; color: var(--accent); }
      .book a { font: 600 13px ui-sans-serif, system-ui, sans-serif; color: #fff;
        background: var(--accent); padding: .45rem .8rem; border-radius: 4px;
        text-decoration: none; white-space: nowrap; }
      .book .none { font: 12px ui-sans-serif, system-ui, sans-serif; color: var(--muted); white-space: nowrap; }
      footer { margin-top: 3rem; font: 12px/1.6 ui-sans-serif, system-ui, sans-serif; color: var(--muted); }
      footer code { background: #efece6; padding: .1rem .35rem; border-radius: 3px; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <a class="back" href={url('/')}>← All guides</a>
      <header class="brand">Curated · adults · design-led · quiet</header>

      {page.header_image && (
        <figure class="hero">
          <img src={url(page.header_image.url_full)} alt={page.header_image.alt_text} loading="eager" />
          <figcaption>
            {page.header_image.photographer_url
              ? <span>{page.header_image.alt_text} · Photo: <a href={page.header_image.photographer_url} rel="nofollow noopener" target="_blank">{page.header_image.photographer}</a> / {page.header_image.provider}</span>
              : <span>{page.header_image.alt_text}</span>}
          </figcaption>
        </figure>
      )}

      <article set:html={bodyHtml}></article>

      {page.pois && page.pois.length > 0 && (
        <section class="pois">
          <h2>What I photographed here</h2>
          {page.pois.map((p) => (
            <figure class="poi">
              <img src={url(p.rep_photo)} alt={p.name} loading="lazy" />
              <figcaption>
                <span class="poi-name">{p.name}</span>
                <p>{p.blurb}</p>
                <span class="poi-credit">Photo: {p.photo_credit}, April 2022 · {p.photo_count} photos here</span>
              </figcaption>
            </figure>
          ))}
        </section>
      )}

      {page.venues.length > 0 && (
      <section class="venues">
        <h2>The shortlist — sources &amp; booking</h2>
        {page.venues.map((v) => (
          <div class="venue">
            <div class="body">
              <div class="name">{v.name}</div>
              <div class="meta">
                {v.venue_type}{v.style_fit ? ` · fit ${Math.round(v.style_fit)}` : ''}
                {v.ownership ? ` · ${v.ownership}` : ''}
              </div>
              {v.sources.length > 0 && (
                <div class="sources">via {v.sources.join(', ')}</div>
              )}
            </div>
            <div class="book">
              {v.link
                ? <a href={v.link.url}
                     rel={v.link.kind === 'affiliate' ? 'sponsored nofollow' : 'nofollow noopener'}
                     target="_blank">{v.link.label}</a>
                : <span class="none">no link yet</span>}
            </div>
          </div>
        ))}
      </section>
      )}

      <footer>
        Every claim on this page traces to a named source in the curation brain.
        Generated from brief <code>{page.source_brief_hash}</code> · version {page.version} · status {page.status}.
      </footer>
    </div>
  </body>
</html>
